@model CMMS.Models.Maquina

@{
    ViewData["Title"] = "Detalles de Máquina";
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-cpu-fill"></i>
                Detalles de la Máquina
            </h3>
        </div>

        <div class="card-body p-4">

            <div class="row mb-3">

                <div class="col-md-3 fw-bold text-secondary">
                    Tipo
                </div>

                <div class="col-md-9">
                    <span class="badge bg-primary">
                        @Model.Tipo
                    </span>
                </div>

            </div>

            <hr />

            <div class="row mb-3">

                <div class="col-md-3 fw-bold text-secondary">
                    Marca
                </div>

                <div class="col-md-9">
                    @Model.Marca
                </div>

            </div>

            <hr />

            <div class="row mb-3">

                <div class="col-md-3 fw-bold text-secondary">
                    Modelo
                </div>

                <div class="col-md-9">
                    @Model.Modelo
                </div>

            </div>

            <hr />

            <div class="row mb-3">

                <div class="col-md-3 fw-bold text-secondary">
                    Serie
                </div>

                <div class="col-md-9">
                    <code>@Model.Serie</code>
                </div>

            </div>

            <hr />

            <div class="row mb-3">

                <div class="col-md-3 fw-bold text-secondary">
                    Cliente
                </div>

                <div class="col-md-9">

                    @(Model.IdClienteNavigation != null
                        ? Model.IdClienteNavigation.Nombres + " " +
                          Model.IdClienteNavigation.Apellidos
                        : "Sin cliente asignado")

                </div>

            </div>

        </div>

        <div class="card-footer bg-light d-flex justify-content-between">

            <a asp-action="Index"
               class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle"></i>
                Regresar
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model?.IdMaquina"
               class="btn btn-warning">
                <i class="bi bi-pencil-square"></i>
                Editar
            </a>

        </div>

    </div>

</div>