@model CMMS.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-person-vcard-fill"></i>
                Detalles del Cliente
            </h3>
        </div>

        <div class="card-body p-4">

            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-secondary">
                    Nombres
                </div>

                <div class="col-md-9">
                    @Model.Nombres
                </div>
            </div>

            <hr />

            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-secondary">
                    Apellidos
                </div>

                <div class="col-md-9">
                    @Model.Apellidos
                </div>
            </div>

            <hr />

            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-secondary">
                    Teléfono
                </div>

                <div class="col-md-9">
                    @Model.Telefono
                </div>
            </div>

            <hr />

            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-secondary">
                    Correo
                </div>

                <div class="col-md-9">
                    @Model.Correo
                </div>
            </div>

            <hr />

            <div class="row mb-3">
                <div class="col-md-3 fw-bold text-secondary">
                    Dirección
                </div>

                <div class="col-md-9">
                    @Model.Direccion
                </div>
            </div>

        </div>

        <div class="card-footer bg-light d-flex justify-content-between">

            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle"></i>
                Regresar
            </a>

            <a asp-action="Edit"
               asp-route-id="@Model?.IdCliente"
               class="btn btn-warning">
                <i class="bi bi-pencil-square"></i>
                Editar
            </a>

        </div>

    </div>

</div>