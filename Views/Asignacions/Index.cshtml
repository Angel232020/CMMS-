@model IEnumerable<CMMS.Models.Asignacion>

@{
    ViewData["Title"] = "Asignaciones";
}

<div class="container mt-4">

    <!-- ENCABEZADO -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

        <h2 class="fw-bold text-primary mb-0">
            <i class="bi bi-person-workspace"></i>
            Gestión de Asignaciones
        </h2>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Nueva Asignación
        </a>

    </div>

    <!-- TABLA -->
    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>
                            <th>Fecha Asignación</th>
                            <th>Orden de Trabajo</th>
                            <th>Técnico</th>
                            <th>Usuario Responsable</th>
                            <th class="text-center">Acciones</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- FECHA -->
                                <td>
                                    @(item.FechaAsignacion != null
                                        ? item.FechaAsignacion?.ToString("dd/MM/yyyy")
                                        : "Sin fecha")
                                </td>

                                <!-- ORDEN -->
                                <td>
                                    @(item.IdOrdenNavigation != null
                                        ? "Orden #" + item.IdOrdenNavigation.IdOrden +
                                          " - " + item.IdOrdenNavigation.Estado
                                        : "Sin orden")
                                </td>

                                <!-- TECNICO -->
                                <td>
                                    @(item.IdTecnicoNavigation != null
                                        ? item.IdTecnicoNavigation.Nombres
                                        : "Sin técnico")
                                </td>

                                <!-- USUARIO -->
                                <td>
                                    @(item.IdUsuarioNavigation != null
                                        ? item.IdUsuarioNavigation.Nombre
                                        : "Sin usuario")
                                </td>

                                <!-- ACCIONES -->
                                <td class="text-center">

                                    <a asp-action="Edit"
                                       asp-route-id="@item.IdAsignacion"
                                       class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a asp-action="Details"
                                       asp-route-id="@item.IdAsignacion"
                                       class="btn btn-info btn-sm text-white">
                                        <i class="bi bi-eye-fill"></i>
                                    </a>

                                    <!-- CANCELAR (soft delete) -->
                                    <a asp-action="Delete"
                                       asp-route-id="@item.IdAsignacion"
                                       class="btn btn-danger btn-sm">
                                        <i class="bi bi-x-circle"></i>
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>