@model IEnumerable<CMMS.Models.Asignacion>

@{
    ViewData["Title"] = "Asignaciones";

    var idRol = User.FindFirst("IdRol")?.Value;
    bool esTecnico = idRol?.Trim() == "2";
    bool esAdmin = !esTecnico;
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

        <div>
            <h2 class="fw-bold text-primary mb-1">
                <i class="bi bi-person-workspace"></i>
                Gestión de Asignaciones
            </h2>

            <p class="text-muted mb-0">
                Control y seguimiento de órdenes asignadas
            </p>
        </div>

        <!-- BOTONES + FILTROS -->
        <div class="d-flex align-items-center gap-2 flex-wrap">

            @if (esAdmin)
            {
                <a asp-action="Create" class="btn btn-primary shadow-sm">
                    <i class="bi bi-plus-circle"></i>
                    Nueva Asignación
                </a>
            }

            <form method="get" asp-action="Index" class="d-flex align-items-center gap-2 flex-wrap">

                <!-- ESTADO -->
                <select name="estado" class="form-select" style="width: 160px;">
                    <option value="">Estado: Todos</option>

                    <option value="PENDIENTE"
                            selected="@(ViewBag.EstadoActual?.ToString() == "PENDIENTE")">
                        PENDIENTE
                    </option>

                    <option value="EN PROCESO"
                            selected="@(ViewBag.EstadoActual?.ToString() == "EN PROCESO")">
                        EN PROCESO
                    </option>

                    <option value="FINALIZADA"
                            selected="@(ViewBag.EstadoActual?.ToString() == "FINALIZADA")">
                        FINALIZADA
                    </option>
                </select>

                @if (esAdmin)
                {
                    <select name="tecnico" class="form-select" style="width: 200px;">
                        <option value="">Técnico: Todos</option>

                        @foreach (var t in ViewBag.Tecnicos as SelectList)
                        {
                            <option value="@t.Value"
                                    selected="@(ViewBag.TecnicoActual?.ToString() == t.Value)">
                                @t.Text
                            </option>
                        }
                    </select>
                }

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-funnel-fill"></i>
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Limpiar
                </a>

            </form>

        </div>

    </div>

    <!-- TABLA -->
    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Orden</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Técnico</th>
                            <th>Responsable</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var estado = item.IdOrdenNavigation?.Estado?.Trim().ToUpper();
                                bool esFinalizada = estado == "FINALIZADA";
                                bool esPendiente = estado == "PENDIENTE";
                                bool enProceso = estado == "EN PROCESO";

                                <tr>

                                    <td class="fw-bold text-primary">
                                        #@item.IdOrdenNavigation?.IdOrden
                                    </td>

                                    <!-- ESTADO -->
                                    <td>
                                        @if (estado == "PENDIENTE")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-clock-history"></i> PENDIENTE
                                            </span>
                                        }
                                        else if (estado == "EN PROCESO")
                                        {
                                            <span class="badge bg-primary">
                                                <i class="bi bi-gear-fill"></i> EN PROCESO
                                            </span>
                                        }
                                        else if (estado == "FINALIZADA")
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle-fill"></i> FINALIZADA
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">SIN ESTADO</span>
                                        }
                                    </td>

                                    <td>
                                        @item.FechaAsignacion?.ToString("dd/MM/yyyy")
                                    </td>

                                    <td>
                                        @(item.IdTecnicoNavigation?.Nombres + " " + item.IdTecnicoNavigation?.Apellidos)
                                    </td>

                                    <td>
                                        @(item.IdUsuarioNavigation?.Nombre)
                                    </td>

                                    <!-- ACCIONES -->
                                    <td class="text-center">

                                        <!-- VER -->
                                        <a asp-action="Details"
                                           asp-route-id="@item.IdAsignacion"
                                           class="btn btn-info btn-sm text-white">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>

                                        <!-- 🔴 BLOQUEO TOTAL SI FINALIZADA -->
                                        @if (!esFinalizada)
                                        {
                                            <!-- TECNICO O ADMIN PUEDEN EJECUTAR FLUJO -->

                                            @if (esPendiente)
                                            {
                                                <form asp-action="Iniciar" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.IdAsignacion" />

                                                    <button type="submit" class="btn btn-primary btn-sm">
                                                        <i class="bi bi-play-fill"></i>
                                                    </button>
                                                </form>
                                            }

                                            @if (enProceso)
                                            {
                                                <form asp-action="Finalizar" method="post" style="display:inline;">
                                                    <input type="hidden" name="id" value="@item.IdAsignacion" />

                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        <i class="bi bi-check2-circle"></i>
                                                    </button>
                                                </form>
                                            }
                                        }

                                        <!-- ADMIN EXTRA ACCIONES -->
                                        @if (esAdmin && !esFinalizada)
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@item.IdAsignacion"
                                               class="btn btn-warning btn-sm">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-action="Delete"
                                               asp-route-id="@item.IdAsignacion"
                                               class="btn btn-danger btn-sm">
                                                <i class="bi bi-x-circle"></i>
                                            </a>
                                        }

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    No hay asignaciones
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>