@model IEnumerable<CMMS.Models.Asignacion>

@{
    ViewData["Title"] = "Asignaciones";

    var idRol = User.FindFirst("IdRol")?.Value;
    bool esTecnico = idRol?.Trim() == "2";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">

        <div>

            <p class="text-muted mb-0">
                Control y seguimiento de órdenes asignadas
            </p>
        </div>

        @if (!esTecnico)
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i>
                Nueva Asignación
            </a>
        }

    </div>

    <!-- FILTRO -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Buscar orden o técnico...">
                </div>

                <div class="col-md-3">
                    <select class="form-select">
                        <option>Filtrar por estado</option>
                        <option>PENDIENTE</option>
                        <option>EN PROCESO</option>
                        <option>FINALIZADA</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <select class="form-select">
                        <option>Filtrar prioridad</option>
                        <option>ALTA</option>
                        <option>MEDIA</option>
                        <option>BAJA</option>
                    </select>
                </div>

            </div>

        </div>

    </div>

    <!-- TABLA -->
    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>Orden</th>
                            <th>Estado</th>
                            <th>Fecha</th>
                            <th>Técnico</th>
                            <th>Responsable</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                var estado = item.IdOrdenNavigation?.Estado?.Trim().ToUpper();

                                <tr>

                                    <!-- ORDEN -->
                                    <td>
                                        <div class="fw-bold text-primary">
                                            #@item.IdOrdenNavigation?.IdOrden
                                        </div>
                                        <small class="text-muted">Orden de trabajo</small>
                                    </td>

                                    <!-- ESTADO -->
                                    <td>
                                        @if (estado == "PENDIENTE")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">
                                                <i class="bi bi-clock-history"></i> Pendiente
                                            </span>
                                        }
                                        else if (estado == "EN PROCESO")
                                        {
                                            <span class="badge bg-primary px-3 py-2">
                                                <i class="bi bi-gear-fill"></i> En Proceso
                                            </span>
                                        }
                                        else if (estado == "FINALIZADA")
                                        {
                                            <span class="badge bg-success px-3 py-2">
                                                <i class="bi bi-check-circle-fill"></i> Finalizada
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2">Sin estado</span>
                                        }
                                    </td>

                                    <!-- FECHA -->
                                    <td>
                                        @if (item.FechaAsignacion != null)
                                        {
                                            <div>@item.FechaAsignacion?.ToString("dd/MM/yyyy")</div>
                                            <small class="text-muted">@item.FechaAsignacion?.ToString("hh:mm tt")</small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin fecha</span>
                                        }
                                    </td>

                                    <!-- TECNICO -->
                                    <td>
                                        @if (item.IdTecnicoNavigation != null)
                                        {
                                            <div class="fw-semibold">
                                                @item.IdTecnicoNavigation.Nombres
                                                @item.IdTecnicoNavigation.Apellidos
                                            </div>
                                            <small class="text-muted">
                                                @item.IdTecnicoNavigation.Especialidad
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Sin técnico</span>
                                        }
                                    </td>

                                    <!-- RESPONSABLE -->
                                    <td>
                                        @(item.IdUsuarioNavigation?.Nombre ?? "Sin responsable")
                                    </td>

                                    <!-- ACCIONES -->
                                    <td class="text-center">

                                        <div class="d-flex justify-content-center gap-1 flex-wrap">

                                            <!-- SIEMPRE VER -->
                                            <a asp-action="Details"
                                               asp-route-id="@item.IdAsignacion"
                                               class="btn btn-info btn-sm text-white">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>

                                            @* 🔴 BLOQUEO TOTAL SI ESTÁ FINALIZADA *@
                                            @if (estado != "FINALIZADA")
                                            {

                                                @if (!esTecnico)
                                                {
                                                    <!-- EDITAR -->
                                                    <a asp-action="Edit"
                                                       asp-route-id="@item.IdAsignacion"
                                                       class="btn btn-warning btn-sm">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>

                                                    <!-- CANCELAR -->
                                                    <a asp-action="Delete"
                                                       asp-route-id="@item.IdAsignacion"
                                                       class="btn btn-danger btn-sm">
                                                        <i class="bi bi-x-circle"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    @* 🔥 BOTONES TECNICO *@

                                                    @if (estado == "PENDIENTE")
                                                    {
                                                        <form asp-action="Iniciar"
                                                              method="post"
                                                              style="display:inline;">
                                                            <input type="hidden" name="id" value="@item.IdAsignacion" />
                                                            <button type="submit"
                                                                    class="btn btn-primary btn-sm">
                                                                <i class="bi bi-play-fill"></i>
                                                            </button>
                                                        </form>
                                                    }

                                                    @if (estado == "EN PROCESO")
                                                    {
                                                        <form asp-action="Finalizar"
                                                              method="post"
                                                              style="display:inline;">
                                                            <input type="hidden" name="id" value="@item.IdAsignacion" />
                                                            <button type="submit"
                                                                    class="btn btn-success btn-sm">
                                                                <i class="bi bi-check2-circle"></i>
                                                            </button>
                                                        </form>
                                                    }
                                                }

                                            }
                                            else
                                            {
                                                <span class="badge bg-dark">
                                                    Solo lectura
                                                </span>
                                            }

                                        </div>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-inbox display-5 text-muted"></i>
                                    <p class="mt-3 text-muted mb-0">
                                        No existen asignaciones registradas
                                    </p>
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>