@model CMMS.Models.Asignacion

@{
    ViewData["Title"] = "Detalle de Asignación";

    var estado = Model?.IdOrdenNavigation?.Estado?.Trim().ToUpper();
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-info text-white">

            <h3 class="mb-0">
                <i class="bi bi-eye-fill"></i>
                Detalle de Asignación
            </h3>

        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <div class="row g-4">

                <!-- FECHA -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Fecha de Asignación
                    </label>

                    <div class="form-control bg-light">

                        @(Model.FechaAsignacion != null
                            ? Model.FechaAsignacion?.ToString("dd/MM/yyyy HH:mm")
                            : "Sin fecha")

                    </div>

                </div>

                <!-- ORDEN -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Orden de Trabajo
                    </label>

                    <div class="form-control bg-light">

                        @(Model.IdOrdenNavigation != null
                            ? "Orden #" + Model.IdOrdenNavigation.IdOrden +
                              " - " + Model.IdOrdenNavigation.Estado
                            : "Sin orden")

                    </div>

                </div>

                <!-- TECNICO -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Técnico
                    </label>

                    <div class="form-control bg-light">

                        @(Model.IdTecnicoNavigation != null
                            ? Model.IdTecnicoNavigation.Nombres + " " +
                              Model.IdTecnicoNavigation.Apellidos
                            : "Sin técnico")

                    </div>

                </div>

                <!-- USUARIO -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Usuario Responsable
                    </label>

                    <div class="form-control bg-light">

                        @(Model.IdUsuarioNavigation != null
                            ? Model.IdUsuarioNavigation.Nombre
                            : "Sin usuario")

                    </div>

                </div>

            </div>

            <hr class="my-4" />

            <!-- BOTONES -->
            <div class="d-flex justify-content-between">

                <a asp-action="Index"
                   class="btn btn-secondary">

                    <i class="bi bi-arrow-left-circle"></i>
                    Regresar

                </a>

                <!-- 🔴 SOLO MUESTRA EDITAR SI NO ESTÁ FINALIZADA -->
                @if (estado != "FINALIZADA")
                {
                    <a asp-action="Edit"
                       asp-route-id="@Model?.IdAsignacion"
                       class="btn btn-warning">

                        <i class="bi bi-pencil-square"></i>
                        Editar

                    </a>
                }

            </div>

        </div>

    </div>

</div>