@model CMMS.Models.Repuesto

@{
    ViewData["Title"] = "Eliminar Repuesto";
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-danger text-white">

            <h3 class="mb-0">
                <i class="bi bi-exclamation-triangle-fill"></i>
                Eliminar Repuesto
            </h3>

        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <h5 class="text-danger mb-4">
                ¿Estás seguro que deseas eliminar este repuesto?
            </h5>

            <div class="row g-4">

                <!-- NOMBRE -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">Nombre</label>
                    <div class="form-control bg-light">
                        @Model.Nombre
                    </div>

                </div>

                <!-- STOCK -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">Stock</label>
                    <div class="form-control bg-light">
                        @Model.Stock
                    </div>

                </div>

                <!-- PRECIO -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">Precio</label>
                    <div class="form-control bg-light">
                        $@Model.Precio
                    </div>

                </div>

            </div>

            <hr class="my-4" />

            <!-- FORM -->
            <form asp-action="Delete">

                <input type="hidden" asp-for="IdRepuesto" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i>
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill"></i>
                        Eliminar
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>