@model CMMS.Models.Repuesto

@{
    ViewData["Title"] = "Crear Repuesto";
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                <i class="bi bi-box-seam"></i>
                Crear Repuesto
            </h3>

        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">

                    <!-- NOMBRE -->
                    <div class="col-md-6">

                        <label asp-for="Nombre" class="fw-bold text-secondary"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>

                    </div>

                    <!-- STOCK -->
                    <div class="col-md-6">

                        <label asp-for="Stock" class="fw-bold text-secondary"></label>
                        <input asp-for="Stock" type="number" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger"></span>

                    </div>

                    <!-- PRECIO -->
                    <div class="col-md-6">

                        <label asp-for="Precio" class="fw-bold text-secondary"></label>
                        <input asp-for="Precio" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Precio" class="text-danger"></span>

                    </div>

                </div>

                <hr class="my-4" />

                <!-- BOTONES -->
                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i>
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i>
                        Crear Repuesto
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}