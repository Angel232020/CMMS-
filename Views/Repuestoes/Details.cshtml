@model CMMS.Models.Repuesto

@{
    ViewData["Title"] = "Detalle de Repuesto";

    bool stockCritico = Model.Stock <= 5;
    bool stockBajo = Model.Stock > 5 && Model.Stock <= 15;
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                <i class="bi bi-box-seam"></i>
                Detalle de Repuesto
            </h3>

        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <div class="row g-4">

                <!-- NOMBRE -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Nombre
                    </label>

                    <div class="form-control bg-light">
                        @Model.Nombre
                    </div>

                </div>

                <!-- STOCK -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Stock
                    </label>

                    <div>

                        @if (stockCritico)
                        {
                            <span class="badge bg-danger fs-6">
                                @Model.Stock - CRÍTICO
                            </span>
                        }
                        else if (stockBajo)
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                @Model.Stock - BAJO
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-success fs-6">
                                @Model.Stock - OK
                            </span>
                        }

                    </div>

                </div>

                <!-- PRECIO -->
                <div class="col-md-6">

                    <label class="fw-bold text-secondary">
                        Precio
                    </label>

                    <div class="form-control bg-light">
                        $@Model.Precio
                    </div>

                </div>

            </div>

            <hr class="my-4" />

            <!-- BOTONES -->
            <div class="d-flex justify-content-between">

                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle"></i>
                    Regresar
                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.IdRepuesto"
                   class="btn btn-warning text-white">
                    <i class="bi bi-pencil-square"></i>
                    Editar Repuesto
                </a>

            </div>

        </div>

    </div>

</div>