@model CMMS.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-person-gear"></i> Editar Usuario
        </h2>

        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left-circle"></i> Regresar
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">

            <form asp-controller="Account" asp-action="Edit" method="post">

                <input type="hidden" asp-for="IdUsuario" />

                <div class="row">

                    <!-- NOMBRE -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <!-- CORREO -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Correo</label>
                        <input asp-for="Correo" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <!-- CONTRASEÑA (opcional) -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Contraseña (dejar vacío si no cambia)</label>
                        <input name="nuevaContrasena" type="password" class="form-control" />
                    </div>

                    <!-- ROL -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Rol</label>
                        <select asp-for="IdRol" class="form-select" asp-items="ViewBag.Roles">
                            <option value="">Seleccione un rol</option>
                        </select>
                        <span asp-validation-for="IdRol" class="text-danger"></span>
                    </div>

                    <!-- ESTADO -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Estado</label>

                        <select asp-for="Estado" class="form-select">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                </div>

                <hr />

                <!-- BOTONES -->
                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index" class="btn btn-light">
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}