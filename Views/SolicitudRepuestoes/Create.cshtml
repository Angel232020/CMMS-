@model CMMS.Models.SolicitudRepuesto

@{
    ViewData["Title"] = "Solicitar Repuesto";
}

<div class="container mt-4">

    <div class="card shadow border-0 rounded-4">

        <!-- HEADER -->
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">
                <i class="bi bi-tools"></i>
                Solicitar Repuesto
            </h3>
        </div>

        <!-- BODY -->
        <div class="card-body p-4">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <!-- ID ASIGNACION OCULTO -->
                <input type="hidden" asp-for="IdAsignacion" value="@Model?.IdAsignacion" />

                <div class="row g-3">

                    <!-- REPUESTO -->
                    <div class="col-md-6">
                        <label asp-for="IdRepuesto" class="form-label fw-bold text-secondary">
                            Repuesto
                        </label>

                        <select asp-for="IdRepuesto" class="form-select shadow-sm" required>
                            <option value="">Seleccione un repuesto</option>

                            @foreach (var repuesto in ViewBag.Repuestos as List<CMMS.Models.Repuesto>)
                            {
                                <option value="@repuesto.IdRepuesto">
                                    @repuesto.Nombre
                                </option>
                            }
                        </select>
                    </div>

                    <!-- CANTIDAD -->
                    <div class="col-md-6">
                        <label asp-for="Cantidad" class="form-label fw-bold text-secondary">
                            Cantidad
                        </label>

                        <input asp-for="Cantidad"
                               type="number"
                               class="form-control shadow-sm"
                               min="1"
                               placeholder="Ingrese cantidad"
                               required />
                    </div>

                    <!-- COMENTARIOS -->
                    <div class="col-md-12">
                        <label asp-for="Comentarios" class="form-label fw-bold text-secondary">
                            Comentarios
                        </label>

                        <textarea asp-for="Comentarios"
                                  class="form-control shadow-sm"
                                  rows="3"
                                  placeholder="Observaciones opcionales"></textarea>
                    </div>

                </div>

                <hr class="my-4" />

                <!-- BOTONES -->
                <div class="d-flex justify-content-between">

                    <a asp-controller="OrdenTrabajo"
                       asp-action="Index"
                       class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i>
                        Regresar
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle-fill"></i>
                        Solicitar Repuesto
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}